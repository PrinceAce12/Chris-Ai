{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the chat" },
        "userId": { "type": "string", "description": "ID of the user who owns this chat" },
        "title": { "type": "string", "description": "Title of the chat" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the chat was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the chat was last updated" }
      },
      "required": ["id", "userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the message" },
        "role": { "type": "string", "enum": ["user", "ai"], "description": "Role of the message sender" },
        "text": { "type": "string", "description": "Content of the message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" },
        "file": {
          "type": "object",
          "properties": {
            "base64": { "type": "string" },
            "mimeType": { "type": "string" },
            "name": { "type": "string" }
          }
        }
      },
      "required": ["id", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "User chats"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    }
  }
}
